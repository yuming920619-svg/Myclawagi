@@ -0,0 +1,188 @@
+import fs from "node:fs/promises";
+import os from "node:os";
+import path from "node:path";
+import type { AgentToolResult } from "@mariozechner/pi-agent-core";
+import { afterEach, describe, expect, it } from "vitest";
+import type { AnyAgentTool } from "./pi-tools.types.js";
+import {
+  createHostReadStateRuntime,
+  createToolReadStateStore,
+  wrapEditToolWithReadStateGuard,
+  wrapReadToolWithState,
+} from "./tool-read-state.js";
+
+function textResult(text: string, details?: unknown): AgentToolResult<unknown> {
+  return {
+    content: [{ type: "text" as const, text }],
+    ...(details === undefined ? {} : { details }),
+  } as AgentToolResult<unknown>;
+}
+
+function createTool(params: {
+  name: string;
+  execute: AnyAgentTool["execute"];
+}): AnyAgentTool {
+  return {
+    name: params.name,
+    description: `${params.name} test tool`,
+    parameters: { type: "object", properties: {} },
+    execute: params.execute,
+  } as unknown as AnyAgentTool;
+}
+
+describe("tool read-state guards", () => {
+  let tmpDir = "";
+
+  afterEach(async () => {
+    if (tmpDir) {
+      await fs.rm(tmpDir, { recursive: true, force: true });
+      tmpDir = "";
+    }
+  });
+
+  async function setupFile(initialContent: string) {
+    tmpDir = await fs.mkdtemp(path.join(os.tmpdir(), "openclaw-read-state-"));
+    const filePath = path.join(tmpDir, "demo.txt");
+    await fs.writeFile(filePath, initialContent, "utf8");
+    return { filePath };
+  }
+
+  it("tracks a full read and refreshes state after a successful edit", async () => {
+    const { filePath } = await setupFile("alpha beta\n");
+    const state = createToolReadStateStore();
+    const runtime = createHostReadStateRuntime({ root: tmpDir });
+
+    const readTool = wrapReadToolWithState(
+      createTool({
+        name: "read",
+        execute: async () => textResult("alpha beta\n"),
+      }),
+      { state, runtime },
+    );
+    const editTool = wrapEditToolWithReadStateGuard(
+      createTool({
+        name: "edit",
+        execute: async () => {
+          await fs.writeFile(filePath, "alpha gamma\n", "utf8");
+          return textResult("edited");
+        },
+      }),
+      { state, runtime },
+    );
+
+    await readTool.execute("read-1", { path: "demo.txt" }, undefined);
+    expect(state.get(filePath)).toMatchObject({
+      isPartialView: false,
+      content: "alpha beta\n",
+    });
+
+    await expect(
+      editTool.execute(
+        "edit-1",
+        { path: "demo.txt", edits: [{ oldText: "beta", newText: "gamma" }] },
+        undefined,
+      ),
+    ).resolves.toMatchObject({
+      content: [{ type: "text", text: "edited" }],
+    });
+
+    expect(await fs.readFile(filePath, "utf8")).toBe("alpha gamma\n");
+    expect(state.get(filePath)).toMatchObject({
+      isPartialView: false,
+      content: "alpha gamma\n",
+    });
+  });
+
+  it("rejects edits when the file was not fully read first", async () => {
+    const { filePath } = await setupFile("alpha beta\n");
+    const state = createToolReadStateStore();
+    const runtime = createHostReadStateRuntime({ root: tmpDir });
+    const editTool = wrapEditToolWithReadStateGuard(
+      createTool({
+        name: "edit",
+        execute: async () => textResult("edited"),
+      }),
+      { state, runtime },
+    );
+
+    await expect(
+      editTool.execute(
+        "edit-1",
+        { path: filePath, edits: [{ oldText: "beta", newText: "gamma" }] },
+        undefined,
+      ),
+    ).rejects.toThrow("File must be fully read before editing");
+  });
+
+  it("marks limited reads as partial and blocks subsequent edits", async () => {
+    const { filePath } = await setupFile("alpha beta\n");
+    const state = createToolReadStateStore();
+    const runtime = createHostReadStateRuntime({ root: tmpDir });
+    const readTool = wrapReadToolWithState(
+      createTool({
+        name: "read",
+        execute: async () =>
+          textResult("alpha\n", {
+            truncation: {
+              truncated: true,
+              outputLines: 1,
+              firstLineExceedsLimit: false,
+            },
+          }),
+      }),
+      { state, runtime },
+    );
+    const editTool = wrapEditToolWithReadStateGuard(
+      createTool({
+        name: "edit",
+        execute: async () => textResult("edited"),
+      }),
+      { state, runtime },
+    );
+
+    await readTool.execute("read-1", { path: "demo.txt", limit: 1 }, undefined);
+    expect(state.get(filePath)).toMatchObject({
+      isPartialView: true,
+      limit: 1,
+    });
+
+    await expect(
+      editTool.execute(
+        "edit-1",
+        { path: "demo.txt", edits: [{ oldText: "beta", newText: "gamma" }] },
+        undefined,
+      ),
+    ).rejects.toThrow("File must be fully read before editing");
+  });
+
+  it("rejects edits when the file changed after the last full read", async () => {
+    const { filePath } = await setupFile("alpha beta\n");
+    const state = createToolReadStateStore();
+    const runtime = createHostReadStateRuntime({ root: tmpDir });
+    const readTool = wrapReadToolWithState(
+      createTool({
+        name: "read",
+        execute: async () => textResult("alpha beta\n"),
+      }),
+      { state, runtime },
+    );
+    const editTool = wrapEditToolWithReadStateGuard(
+      createTool({
+        name: "edit",
+        execute: async () => textResult("edited"),
+      }),
+      { state, runtime },
+    );
+
+    await readTool.execute("read-1", { path: "demo.txt" }, undefined);
+    await fs.writeFile(filePath, "alpha delta\n", "utf8");
+
+    await expect(
+      editTool.execute(
+        "edit-1",
+        { path: "demo.txt", edits: [{ oldText: "delta", newText: "gamma" }] },
+        undefined,
+      ),
+    ).rejects.toThrow("File changed since last read");
+  });
+});
