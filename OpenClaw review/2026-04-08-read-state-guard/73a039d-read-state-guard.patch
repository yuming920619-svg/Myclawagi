+import { createHash } from "node:crypto";
+import fs from "node:fs/promises";
+import type {
+  AgentToolResult,
+  AgentToolUpdateCallback,
+} from "@mariozechner/pi-agent-core";
+import type { AnyAgentTool } from "./pi-tools.types.js";
+import { getToolParamsRecord } from "./pi-tools.params.js";
+import type { SandboxFsBridge } from "./sandbox/fs-bridge.js";
+import { resolveToolPathAgainstWorkspaceRoot } from "./tool-path-resolution.js";
+
+export type ReadState = {
+  content: string;
+  timestamp: number;
+  offset?: number;
+  limit?: number;
+  isPartialView?: boolean;
+  contentHash?: string;
+};
+
+export type ToolReadStateStore = Map<string, ReadState>;
+
+type ReadStatePathOptions = {
+  root: string;
+  containerWorkdir?: string;
+};
+
+type ReadStateRuntime = ReadStatePathOptions & {
+  readFileUtf8: (absolutePath: string, signal?: AbortSignal) => Promise<string>;
+};
+
+function sha256(input: string): string {
+  return createHash("sha256").update(input).digest("hex");
+}
+
+function readStringParam(record: Record<string, unknown> | undefined, ...keys: string[]) {
+  for (const key of keys) {
+    const value = record?.[key];
+    if (typeof value === "string" && value.trim()) {
+      return value;
+    }
+  }
+  return undefined;
+}
+
+function readNumberParam(record: Record<string, unknown> | undefined, ...keys: string[]) {
+  for (const key of keys) {
+    const value = record?.[key];
+    if (typeof value === "number" && Number.isFinite(value)) {
+      return value;
+    }
+    if (typeof value === "string" && value.trim()) {
+      const parsed = Number(value);
+      if (Number.isFinite(parsed)) {
+        return parsed;
+      }
+    }
+  }
+  return undefined;
+}
+
+function resolveFilePathParam(record: Record<string, unknown> | undefined): string | undefined {
+  return readStringParam(record, "path", "filePath", "file_path", "file");
+}
+
+function hasImageContent(result: AgentToolResult<unknown>): boolean {
+  const content = Array.isArray(result.content) ? result.content : [];
+  return content.some(
+    (block) =>
+      !!block && typeof block === "object" && (block as { type?: unknown }).type === "image",
+  );
+}
+
+function isReadResultPartial(
+  result: AgentToolResult<unknown>,
+  params: { offset?: number; limit?: number },
+): boolean {
+  if (params.offset !== undefined || params.limit !== undefined) {
+    return true;
+  }
+  const details = (result as { details?: unknown }).details;
+  if (!details || typeof details !== "object") {
+    return false;
+  }
+  const truncation = (details as { truncation?: unknown }).truncation;
+  if (!truncation || typeof truncation !== "object") {
+    return false;
+  }
+  return (truncation as { truncated?: unknown }).truncated === true;
+}
+
+function buildReadState(content: string, params?: { offset?: number; limit?: number }): ReadState {
+  return {
+    content,
+    timestamp: Date.now(),
+    offset: params?.offset,
+    limit: params?.limit,
+    isPartialView: false,
+    contentHash: sha256(content),
+  };
+}
+
+function buildPartialReadState(params?: { offset?: number; limit?: number }): ReadState {
+  return {
+    content: "",
+    timestamp: Date.now(),
+    offset: params?.offset,
+    limit: params?.limit,
+    isPartialView: true,
+  };
+}
+
+export function createToolReadStateStore(): ToolReadStateStore {
+  return new Map<string, ReadState>();
+}
+
+export function createHostReadStateRuntime(params: ReadStatePathOptions): ReadStateRuntime {
+  return {
+    ...params,
+    readFileUtf8: async (absolutePath) => await fs.readFile(absolutePath, "utf8"),
+  };
+}
+
+export function createSandboxReadStateRuntime(params: {
+  root: string;
+  bridge: SandboxFsBridge;
+  containerWorkdir?: string;
+}): ReadStateRuntime {
+  return {
+    root: params.root,
+    containerWorkdir: params.containerWorkdir,
+    readFileUtf8: async (absolutePath, signal) =>
+      (
+        await params.bridge.readFile({
+          filePath: absolutePath,
+          cwd: params.root,
+          signal,
+        })
+      ).toString("utf8"),
+  };
+}
+
+export function wrapReadToolWithState(
+  tool: AnyAgentTool,
+  params: {
+    state: ToolReadStateStore;
+    runtime: ReadStateRuntime;
+  },
+): AnyAgentTool {
+  return {
+    ...tool,
+    execute: async (
+      toolCallId: string,
+      rawParams: unknown,
+      signal: AbortSignal | undefined,
+      onUpdate?: AgentToolUpdateCallback<unknown>,
+    ) => {
+      const result = (await tool.execute(
+        toolCallId,
+        rawParams,
+        signal,
+        onUpdate,
+      )) as AgentToolResult<unknown>;
+
+      const record = getToolParamsRecord(rawParams);
+      const filePath = resolveFilePathParam(record);
+      if (!filePath) {
+        return result;
+      }
+
+      const absolutePath = resolveToolPathAgainstWorkspaceRoot({
+        filePath,
+        root: params.runtime.root,
+        containerWorkdir: params.runtime.containerWorkdir,
+      });
+      if (hasImageContent(result)) {
+        params.state.delete(absolutePath);
+        return result;
+      }
+      const offset = readNumberParam(record, "offset");
+      const limit = readNumberParam(record, "limit");
+
+      if (isReadResultPartial(result, { offset, limit })) {
+        params.state.set(absolutePath, buildPartialReadState({ offset, limit }));
+        return result;
+      }
+
+      try {
+        const content = await params.runtime.readFileUtf8(absolutePath, signal);
+        params.state.set(absolutePath, buildReadState(content, { offset, limit }));
+      } catch {
+        params.state.delete(absolutePath);
+      }
+      return result;
+    },
+  };
+}
+
+export function wrapEditToolWithReadStateGuard(
+  tool: AnyAgentTool,
+  params: {
+    state: ToolReadStateStore;
+    runtime: ReadStateRuntime;
+  },
+): AnyAgentTool {
+  return {
+    ...tool,
+    execute: async (
+      toolCallId: string,
+      rawParams: unknown,
+      signal: AbortSignal | undefined,
+      onUpdate?: AgentToolUpdateCallback<unknown>,
+    ) => {
+      const record = getToolParamsRecord(rawParams);
+      const filePath = resolveFilePathParam(record);
+      if (!filePath) {
+        return await tool.execute(toolCallId, rawParams, signal, onUpdate);
+      }
+
+      const absolutePath = resolveToolPathAgainstWorkspaceRoot({
+        filePath,
+        root: params.runtime.root,
+        containerWorkdir: params.runtime.containerWorkdir,
+      });
+      const lastRead = params.state.get(absolutePath);
+      if (!lastRead || lastRead.isPartialView) {
+        throw new Error("File must be fully read before editing");
+      }
+
+      const currentContent = await params.runtime.readFileUtf8(absolutePath, signal);
+      if (lastRead.contentHash && sha256(currentContent) !== lastRead.contentHash) {
+        throw new Error("File changed since last read");
+      }
+
+      const result = await tool.execute(toolCallId, rawParams, signal, onUpdate);
+      const updatedContent = await params.runtime.readFileUtf8(absolutePath, signal);
+      params.state.set(absolutePath, buildReadState(updatedContent));
+      return result;
+    },
+  };
+}
